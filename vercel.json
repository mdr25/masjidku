{
  "rewrites": [
    {
      "source": "/api-wilayah/:path*",
      "destination": "https://raw.githubusercontent.com/emsifa/api-wilayah-indonesia/gh-pages/api/:path*"
    },
    {
      "source": "/api-prayer/:path*",
      "destination": "https://masjidku-api.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
